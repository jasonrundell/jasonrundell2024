                  "fill": "$ink",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Clarity Leads to Growth: Why Vague Hints in Code Reviews Can Be Counterproductive",
                  "lineHeight": 1.18,
                  "fontFamily": "Newsreader",
                  "fontSize": 40,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "QtMqp",
                  "fill": "$inkMuted",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Vague hints slow growth. Clear, specific feedback helps developers learn faster, avoid repeat mistakes, and build confidence. Don’t just lead them to water—show them how to drink.",
                  "lineHeight": 1.5,
