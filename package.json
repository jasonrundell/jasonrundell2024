{
  "name": "jasonrundell2024",
  "description": "Jason Rundell's personal website",
  "version": "1.4.0",
  "author": "Jason Rundell <jason.rundell@gmail.com>",
  "keywords": [
    "next.js",
    "contentful",
    "react",
    "pigment-css"
  ],
  "scripts": {
    "dell": "npm run dev",
    "predev": "npm run tokens:build && node ./scripts/sync-content-images.js",
    "dev": "next",
    "prebuild": "npm run tokens:build && node ./scripts/sync-content-images.js",
    "build": "next build",
    "start": "next start",
    "start:ci": "next start",
    "lint": "next lint",
    "tokens:build": "node ./scripts/build-tokens.js",
    "tokens:check": "npm run tokens:build && git diff --exit-code -- src/lib/tokens.generated.ts src/styles/tokens.generated.css",
    "illustrations:build": "node ./scripts/build-illustrations.js",
    "lighthouse:ci": "lhci autorun",
    "test": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "test:a11y": "jest --ci --runTestsByPath src/app/accessibility.test.tsx",
    "test:coverage": "jest --coverage --coverageReporters=json-summary --coverageReporters=text && node ./scripts/check-coverage.js",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --coverageReporters=json-summary --coverageReporters=text && node ./scripts/check-coverage.js",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "analyze": "cross-env ANALYZE=true npm run build",
    "clear-cache": "rimraf .next node_modules/.cache"
  },
  "dependencies": {
    "@pigment-css/react": "^0.0.30",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.2",
    "@supabase/ssr": "^0.6.1",
    "@vercel/speed-insights": "^1.1.0",
    "date-fns": "^4.1.0",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.475.0",
    "next": "^15.5.15",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@jasonrundell/dropship": "^3.3.0",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "15.5.15",
    "@next/third-parties": "^15.5.15",
    "@pigment-css/nextjs-plugin": "^0.0.30",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/supabase-js": "^2.49.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/testing-library__jest-dom": "^5.14.9",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.11.4",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.35",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.1",
    "postcss": "^8.4.47",
    "postcss-normalize": "^13.0.1",
    "react-axe": "^3.5.4",
    "sharp": "^0.33.5",
    "typescript": "^5.8.3",
    "webpack": "^5.106.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonrundell/jasonrundell2024"
  },
  "bugs": {
    "url": "https://github.com/jasonrundell/jasonrundell2024/issues"
  },
  "overrides": {
    "happy-dom": ">=20.0.0",
    "glob": ">=10.5.0",
    "test-exclude": ">=7.0.0"
  }
}
